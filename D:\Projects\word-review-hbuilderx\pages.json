{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "单词记忆",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/detail/detail",
      "style": {
        "navigationBarTitleText": "单词详情"
      }
    },
    {
      "path": "pages/review/review",
      "style": {
        "navigationBarTitleText": "智能复习"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "单词记忆",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#3cc51f",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/icon-word.png",
        "selectedIconPath": "static/icon-word-active.png",
        "text": "单词列表"
      },
      {
        "pagePath": "pages/review/review",
        "iconPath": "static/icon-review.png",
        "selectedIconPath": "static/icon-review-active.png",
        "text": "智能复习"
      }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  }
}
